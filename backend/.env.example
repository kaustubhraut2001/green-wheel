# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Multi-Currency Wallet Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
# Used by FastAPI (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://wallet_user:wallet_pass@postgres:5432/wallet_db

# PostgreSQL container credentials
POSTGRES_USER=wallet_user
POSTGRES_PASSWORD=wallet_pass
POSTGRES_DB=wallet_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300
EXCHANGE_RATE_CACHE_TTL=3600

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a secure random value for production
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_A_STRONG_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Exchange Rate Provider ────────────────────────────────────────────────────
# Options: open_exchange | fixer | mock
EXCHANGE_RATE_PROVIDER=mock

# Open Exchange Rates (https://openexchangerates.org)
OPEN_EXCHANGE_APP_ID=your_app_id_here

# Fixer.io (https://fixer.io)
FIXER_API_KEY=your_fixer_key_here

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE_MB=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=3/minute
RATE_LIMIT_DEFAULT=60/minute
